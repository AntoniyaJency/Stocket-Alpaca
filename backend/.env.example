# ─────────────────────────────────────────────────────────────────
#  AlgoTrade v2 Environment Variables
# ─────────────────────────────────────────────────────────────────

# Alpaca Trading API (Get from https://app.alpaca.markets)
ALPACA_KEY_ID=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_MODE=paper  # Keep as "paper" for testing, change to "live" for real money

# AI API Key (Groq - Fastest & Cheapest)
GROQ_API_KEY=your_groq_api_key_here

# Security
JWT_SECRET=your_jwt_secret_here_at_least_32_characters_long

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:3000

# Auto-trading Settings
AUTO_TRADE_ENABLED=false       # Set true to auto-start on launch
AUTO_TRADE_QTY=1               # Shares per auto-trade
AUTO_TRADE_MAX_POSITION=5      # Max shares held per stock
AUTO_TRADE_INTERVAL_SECONDS=60 # How often AI scans & trades

# Risk Management
RISK_PER_TRADE_PCT=2           # Risk percentage per trade
DAILY_LOSS_LIMIT_PCT=5         # Daily loss limit percentage
MIN_CONFIDENCE=65              # Minimum confidence level for trades

# Strategy Configuration
STRATEGY=combined              # Options: rsi, sma, momentum, volatility, combined
